generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Permission {
  id          Int      @id @default(autoincrement())
  action      String // Ej: "create", "read", "update", "delete"
  subject     String // Ej: "User", "Application", "Role"
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@unique([action, subject])
  @@map("permissions")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String // Ej: "Validador Senior"
  slug        String    @unique // Ej: "VALIDATOR"
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// NUEVA TABLA: Información física y demográfica
model Person {
  id Int @id @default(autoincrement())

  // Identificación
  documentType   String @map("document_type") // DNI, CE, PASSPORT
  documentNumber String @unique @map("document_number")

  // Nombres completos
  firstName        String  @map("first_name")
  paternalLastName String  @map("paternal_last_name")
  maternalLastName String? @map("maternal_last_name") // Opcional

  // Demografía
  birthDate  DateTime? @map("birth_date") @db.Date
  birthPlace String?   @map("birth_place")
  gender     String?

  // Ubicación Geográfica
  country    String? @default("Peru")
  department String?
  province   String?
  district   String?
  address    String?

  // Contacto
  phone          String?
  secondaryEmail String? @map("secondary_email")

  // Auditoría
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relación inversa (1 a 1)
  user User?

  @@map("persons")
}

// TABLA DE ACCESO: Exclusivamente para credenciales y roles
model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  // Llaves Foráneas
  roleId   Int? @map("role_id")
  personId Int? @unique @map("person_id") // Relación 1 a 1 estricta

  // Auditoría
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relaciones
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  person Person? @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("users")
}

